APP_NAME=AcadFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -------------------------------------------------------
# DATABASE — configure no painel do Laravel Cloud
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acadflow
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------
# SESSION / CACHE / QUEUE
# -------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# -------------------------------------------------------
# STORAGE — para uploads persistentes no Cloud use S3
# Defina FILESYSTEM_DISK=s3 e configure as vars AWS_* abaixo
# -------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------------------------------------
# BROADCASTING (Reverb) — opcional
# Sem estas vars o app funciona via polling. Para ativar
# notificações em tempo real, configure e defina
# BROADCAST_CONNECTION=reverb
# -------------------------------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

# Vars VITE_ são embutidas no JS no momento do build.
# Devem estar definidas no painel do Cloud ANTES do deploy.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -------------------------------------------------------
# LOGIN COM GOOGLE (OAuth via Socialite)
# Crie as credenciais em console.cloud.google.com e registre o redirect URI.
# Dev: http://localhost:8000/api/auth/google/callback
# Prod: https://SEU-DOMINIO/api/auth/google/callback
# -------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# -------------------------------------------------------
# IA — geração de plano de trabalho (Anthropic / Claude)
# Chave em console.anthropic.com (sk-ant-...). Fica só no servidor.
# -------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@acadflow.app"
MAIL_FROM_NAME="${APP_NAME}"
