APP_NAME=AcadFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -------------------------------------------------------
# ADMIN inicial (seed automático). Deixe em branco para NÃO criar admin.
# NUNCA versione a senha real: defina apenas no ambiente/painel.
# -------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME="Administrador"

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -------------------------------------------------------
# DATABASE — configure no painel do Laravel Cloud
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acadflow
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------
# SESSION / CACHE / QUEUE
# -------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Cookies de sessão só trafegam sob HTTPS. Deixe true em produção.
# Em dev sob http (localhost) mantenha false, senão o cookie não é enviado.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Domínios que recebem cookies de autenticação stateful (Sanctum SPA).
# Inclua o host da SPA. Em produção, use o domínio do app.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Expiração dos tokens de API (minutos). Sessões de 1ª parte não são afetadas.
SANCTUM_TOKEN_EXPIRATION=20160

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# -------------------------------------------------------
# UPLOADS (avatares e anexos)
# Local: deixe em branco (usa o disco "public" + storage:link).
# Produção (Laravel Cloud): defina UPLOAD_DISK=s3 para os arquivos
# persistirem entre deploys. As vars AWS_* abaixo são injetadas
# automaticamente ao conectar um bucket de Object Storage no Cloud.
# -------------------------------------------------------
UPLOAD_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------------------------------------
# BROADCASTING (Reverb) — opcional
# Sem estas vars o app funciona via polling. Para ativar
# notificações em tempo real, configure e defina
# BROADCAST_CONNECTION=reverb
# -------------------------------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

# Vars VITE_ são embutidas no JS no momento do build.
# Devem estar definidas no painel do Cloud ANTES do deploy.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -------------------------------------------------------
# LOGIN COM GOOGLE (OAuth via Socialite)
# Crie as credenciais em console.cloud.google.com e registre o redirect URI.
# Dev: http://localhost:8000/api/auth/google/callback
# Prod: https://SEU-DOMINIO/api/auth/google/callback
# -------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# -------------------------------------------------------
# IA — geração de plano de trabalho (Anthropic / Claude)
# Chave em console.anthropic.com (sk-ant-...). Fica só no servidor.
# -------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Dev: 'log' grava o e-mail em storage/logs (o código do OTP aparece lá).
# Produção: use 'resend' (defina RESEND_API_KEY abaixo) ou 'smtp'.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@acadflow.app"
MAIL_FROM_NAME="${APP_NAME}"

# E-mail transacional (Resend). Chave em https://resend.com/api-keys (re_...).
# Para MAIL_MAILER=resend, o MAIL_FROM_ADDRESS deve usar um domínio verificado
# na Resend (ou onboarding@resend.dev para testes só com o seu próprio e-mail).
RESEND_API_KEY=

# -------------------------------------------------------
# Pagamentos — ASAAS (assinaturas Pro / Ultra Pro)
# Chave em: ASAAS > Configurações > Integrações > API
# Comece no SANDBOX (ambiente de testes, grátis).
# -------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=
# Redirect automático pós-pagamento. Só ative (true) após cadastrar um site na
# conta ASAAS (Minha Conta > Informações), senão a assinatura falha com 400.
ASAAS_ENABLE_CALLBACK=false
PLAN_GRACE_DAYS=3
